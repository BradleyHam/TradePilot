# Trade Pilot environment — copy to .env.local and fill in real values.
# .env.local is gitignored.

# Public Supabase config — used by the browser client.
# Found in Supabase dashboard → Settings → API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_REPLACE_ME

# Service-role key — bypasses RLS. Used by server-side scripts (the
# importer) AND by the website-enquiry webhook route. Never imported by
# client components.
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────
# Website enquiry webhook (POST /api/webhooks/website-enquiry)
# ─────────────────────────────────────────────────────────────────────────
# Shared secret — the painterswanaka.co.nz contact-form handler must send
# this in the `x-webhook-secret` header. Generate with:
#   openssl rand -hex 32
# WEBSITE_WEBHOOK_SECRET=

# Which business inbound website enquiries should be added to. Look up in
# Supabase → Table editor → businesses → copy the id of Lakeside Painting.
# TRADEPILOT_BUSINESS_ID=

# ─────────────────────────────────────────────────────────────────────────
# Anthropic API key (POST /api/parse-bill)
# ─────────────────────────────────────────────────────────────────────────
# Used server-side by the bill-PDF parser to extract supplier/amount/GST
# from uploaded invoices. NEVER expose as NEXT_PUBLIC_ — that would ship
# the key to the browser. Get one from console.anthropic.com → API Keys.
# At ~$0.005 per bill (Haiku 4.5), $5 of credit is ~1000 bills.
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────
# Inbound-bill webhook (POST /api/webhooks/inbound-bill)
# ─────────────────────────────────────────────────────────────────────────
# Shared secret expected in the `x-webhook-secret` header on every
# incoming request. The mail-receiver service (e.g. CloudMailin) must be
# configured to send this header. Generate with:
#   openssl rand -hex 32
# INBOUND_BILL_WEBHOOK_SECRET=
