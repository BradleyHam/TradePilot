# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Google service-account credentials. NEVER commit. The exporter scripts
# need this present at scripts/service-worker.json.
scripts/service-worker.json

# Imported data dumps — contain real business financials. Don't commit.
/data/import/

# Editor
.vscode/
.idea/
scripts/import-projects-mapping.csv
